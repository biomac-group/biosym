
<mujoco model="cartpole">
  <compiler coordinate="local" inertiafromgeom="true"/>
  <custom>
    <numeric data="2" name="frame_skip"/>
  </custom>
  <default>
    <joint damping="0.05"/>
    <geom contype="0" friction="1 0.1 0.1" rgba="0.7 0.7 0 1"/>
  </default>
  <option gravity="1e-5 0 -9.81" integrator="RK4" timestep="0.01"/>
  <size nstack="3000"/>
  <worldbody>
    <geom name="floor" pos="0 0 -3.0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane"/>
    <geom name="rail" pos="0 0 0" quat="0.707 0 0.707 0" rgba="0.3 0.3 0.7 1" size="0.02 1" type="capsule"/>
    <body name="pole" pos="0 0 0">
      <joint axis="0 0 1" name="hinge" pos="0 0 0" type="hinge"/>
      <geom fromto="0 0 0 0 0 0.6" name="cpole" rgba="0 0.7 0.7 1" size="0.045 0.3" type="capsule"/>
      <body name="pole2" pos="0 1 0">
        <joint axis="0 0 1" name="hinge2" pos="0 0 0" type="hinge"/>
        <geom fromto="0 0 0 0 0 0.6" name="cpole2" rgba="0 0.7 0.7 1" size="0.045 0.3" type="capsule"/>
        <site name="tip" pos="0 0 .6" size="0.01 0.01"/>
        <body name="pole3" pos="0 1 0">
          <joint axis="0 0 1" name="hinge3" pos="0 0 0" type="hinge"/>
          <body name="pole4" pos="0 1 0">
            <joint axis="0 0 1" name="hinge4" pos="0 0 0" type="hinge"/>
            <body name="pole5" pos="0 1 0">
              <joint axis="0 0 1" name="hinge5" pos="0 0 0" type="hinge"/>
              <body name="pole6" pos="0 1 0">
                <joint axis="0 0 1" name="hinge6" pos="0 0 0" type="hinge"/>
                <body name="pole7" pos="0 1 0">
                  <joint axis="0 0 1" name="hinge7" pos="0 0 0" type="hinge"/>
                  <body name="pole8" pos="0 1 0">
                    <joint axis="0 0 1" name="hinge8" pos="0 0 0" type="hinge"/>
                    <body name="pole9" pos="0 1 0">
                      <joint axis="0 0 1" name="hinge9" pos="0 0 0" type="hinge"/>
                      <body name="pole10" pos="0 1 0">
                        <joint axis="0 0 1" name="hinge10" pos="0 0 0" type="hinge"/>
                      </body>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="500" joint="slider" name="slide"/>
  </actuator>
</mujoco>