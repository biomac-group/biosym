<mujoco model="cartpole">
  <compiler coordinate="local" inertiafromgeom="true"/>
  <custom>
    <numeric data="2" name="frame_skip"/>
  </custom>
  <default>
    <joint damping="0.3"/>
    <geom contype="0" friction="1 0.1 0.1" rgba="0.7 0.7 0 1"/>
  </default>
  <option gravity="0 -9.81 0" integrator="RK4" timestep="0.01"/>
  <size nstack="3000"/>
  <worldbody>
    <geom name="floor" pos="0 0 -3.0" rgba="0.8 0.9 0.8 1" size="40 40 40" type="plane"/>
    <geom name="rail" pos="0 0 0" quat="0.707 0 0.707 0" rgba="0.3 0.3 0.7 1" size="0.02 1" type="capsule"/>
    <body name="pole" pos="0 0 0">
      <inertial pos="0 0.5 0" mass="1" fullinertia="1 1 1 0 0 0"></inertial>
      <joint axis="0 0 1" name="hinge" pos="0 0 0" type="hinge"/>
      <geom fromto="0 0 0 0 0 0.6" name="cpole" rgba="0 0.7 0.7 1" size="0.045 0.3" type="capsule"/>
      <body name="pole2" pos="0 1 0">
        <inertial pos="0 0.5 0" mass="1" fullinertia="1 1 1 0 0 0"></inertial>
        <joint axis="0 0 1" name="hinge2" pos="0 0 0" type="hinge"/>
        <geom fromto="0 0 0 0 0 0.6" name="cpole2" rgba="0 0.7 0.7 1" size="0.045 0.3" type="capsule"/>
        <site name="vis_tip" pos="0 1 0" size="0.01 0.01"/>
        <!-- To plot the end of the body, we can set it in an .xml file OR create a massless body with an extra joint (This will make computation slower) -->
        <!-- Here, we see an issue: the body cannot be exactly "massless", because that will cause NaNs in the forward simulation, so i've set it to 1e-12 -->
        <!-- TODO: parse the "site" as the tip of the pole-->
      </body>
    </body>
  </worldbody>
  <actuator>
    <motor ctrllimited="true" ctrlrange="-1 1" gear="500" joint="hinge" name="slide"/>
  </actuator>
</mujoco>